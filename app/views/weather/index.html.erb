<h2>Find your local weather</h2>

<%= form_with url: weather_path, method: :post do |form| %>
  <div class="form-group">
    <%= form.label :city, "City:" %>
    <%= form.text_field :city, required: true, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :state, "State:" %>
    <%= form.text_field :state, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :country, "Country:" %>
    <%= form.text_field :country, class: "form-control" %>
  </div>

  <%= form.submit "Get Weather", class: "btn btn-primary" %>
<% end %>
